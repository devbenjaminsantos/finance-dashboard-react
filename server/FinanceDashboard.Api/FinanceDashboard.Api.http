@FinanceDashboard.Api_HostAddress = http://localhost:5278
@contentType = application/json
@authToken = COLE_SEU_JWT_AQUI

### Registrar usuário
POST {{FinanceDashboard.Api_HostAddress}}/api/auth/register
Content-Type: {{contentType}}

{
  "name": "Usuário Teste",
  "email": "teste@finova.local",
  "password": "SenhaForte123"
}

### Login
POST {{FinanceDashboard.Api_HostAddress}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "teste@finova.local",
  "password": "SenhaForte123"
}

### Listar transações
GET {{FinanceDashboard.Api_HostAddress}}/api/transactions
Authorization: Bearer {{authToken}}
Accept: {{contentType}}

### Criar transação
POST {{FinanceDashboard.Api_HostAddress}}/api/transactions
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "description": "Salario",
  "category": "Trabalho",
  "amountCents": 350000,
  "date": "2026-03-31T00:00:00Z",
  "type": "income"
}
